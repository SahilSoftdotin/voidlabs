# ============================================================
# SECURITY & PERFORMANCE HEADERS
# ============================================================
# Add this to your server configuration or use a service like Netlify/Vercel

# X-Frame-Options: Prevent clickjacking
X-Frame-Options: SAMEORIGIN

# X-Content-Type-Options: Prevent MIME type sniffing
X-Content-Type-Options: nosniff

# X-XSS-Protection: Enable XSS protection
X-XSS-Protection: 1; mode=block

# Referrer-Policy: Control referrer information
Referrer-Policy: strict-origin-when-cross-origin

# Permissions-Policy: Control browser features
Permissions-Policy: geolocation=(), microphone=(), camera=()

# Content-Security-Policy: Prevent injection attacks
Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self';

# Cache Control: Static assets
Cache-Control: public, max-age=31536000, immutable

# GZIP Compression
Accept-Encoding: gzip, deflate

# For Netlify users, add this to netlify.toml instead
